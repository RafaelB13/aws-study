{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@ui/*": ["ui/*"]
    },
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "ui/**/*",
    "**/*.spec.ts",
    "**/*.test.ts",
    "vite.config.ts"
  ]
}
